# ============================================
# Environment variables for demo-park-api
# Copy this file to .env and fill in your values
# ============================================

# MySQL Database
DB_URL=jdbc:mysql://localhost:3306/park_api?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=America/Sao_Paulo
DB_USERNAME=root
DB_PASSWORD=your_password_here

# JWT Secret Key (min 32 chars for HS256)
JWT_SECRET_KEY=your-jwt-secret-key-at-least-32-characters-long
